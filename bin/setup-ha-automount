#!/usr/bin/env bash
# setup-ha-automount: install a system-level SSHFS automount of the Home
# Assistant SSH addon's /config at /mnt/ha-config.
#
# Run with sudo. Idempotent.
#
# Reads the SSH private key from the invoking user's
# ~/.config/home-assistant/id_ed25519 (materialized by dev-setup's
# install-secrets.sh from Infisical). Copies it to /etc/ssh/ha-config-key
# (root:root, 0600) so root can read it for the system mount.
#
# Installs:
#   /etc/ssh/ha-config-key                  -- copy of the SSH key
#   /etc/ssh/ha-config-known_hosts          -- isolated known_hosts file
#   /etc/systemd/system/mnt-ha\x2dconfig.mount       -- the .mount unit
#   /etc/systemd/system/mnt-ha\x2dconfig.automount   -- the .automount unit
#   /mnt/ha-config                          -- the mountpoint dir
#
# Once installed, the mount is on-demand: any access to /mnt/ha-config
# triggers it; after 5 minutes idle it unmounts. SSH keepalive options
# transparently reconnect across HA addon restarts.
#
# Manual control:
#   sudo systemctl status mnt-ha\\x2dconfig.automount
#   sudo systemctl stop   mnt-ha\\x2dconfig.mount       # one-off unmount
#   sudo systemctl restart mnt-ha\\x2dconfig.automount
#   sudo umount /mnt/ha-config                          # equivalent

set -euo pipefail

log()  { printf '\033[1;34m[setup-ha-automount]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[setup-ha-automount]\033[0m %s\n' "$*" >&2; }
fail() { printf '\033[1;31m[setup-ha-automount]\033[0m %s\n' "$*" >&2; exit 1; }

# Configurable knobs (env-var overrides for non-default deployments).
HA_SSH_HOST="${HA_SSH_HOST:-root@192.168.0.79}"
# /config on the addon is a symlink to /homeassistant; sshfs can't follow
# symlinks at the root path, so mount the canonical target.
HA_SSH_REMOTE_PATH="${HA_SSH_REMOTE_PATH:-/homeassistant}"
HA_MOUNT_POINT="${HA_MOUNT_POINT:-/mnt/ha-config}"
HA_IDLE_TIMEOUT="${HA_IDLE_TIMEOUT:-300}"  # seconds before idle-unmount

# Must run as root.
if [[ $EUID -ne 0 ]]; then
  fail "must run as root (try: sudo $0)"
fi

# Identify the invoking user so we can find their SSH key materialized by
# dev-setup. SUDO_USER is set by sudo; fall back to the owner of $PWD if
# someone runs us via su or similar.
if [[ -n "${SUDO_USER:-}" && "$SUDO_USER" != "root" ]]; then
  invoking_user="$SUDO_USER"
else
  warn "no SUDO_USER set; assuming the SSH key is at /root/.config/home-assistant/id_ed25519"
  invoking_user="root"
fi
user_home="$(getent passwd "$invoking_user" | cut -d: -f6)"
[[ -d "$user_home" ]] || fail "could not resolve home dir for user '$invoking_user'"

src_key="$user_home/.config/home-assistant/id_ed25519"
[[ -f "$src_key" ]] || fail "SSH key not found at $src_key
  Expected dev-setup's install-secrets.sh to have materialized it from Infisical.
  Run 'install.sh' first, then re-run this script."

# Required system tools.
for cmd in sshfs mount.fuse.sshfs systemctl systemd-escape install; do
  command -v "$cmd" >/dev/null 2>&1 || fail "missing required command: $cmd
  on Debian/Ubuntu: apt install sshfs
  on Arch:          pacman -S sshfs"
done

# 1. Copy the SSH key into a root-owned location.
key_dst="/etc/ssh/ha-config-key"
known_hosts="/etc/ssh/ha-config-known_hosts"
install -m 0600 -o root -g root "$src_key" "$key_dst"
touch "$known_hosts"
chmod 0644 "$known_hosts"
chown root:root "$known_hosts"
log "installed SSH key -> $key_dst"

# 2. Create the mountpoint.
mkdir -p "$HA_MOUNT_POINT"
log "ensured mountpoint: $HA_MOUNT_POINT"

# 3. Compute systemd unit names from the mount path.
# /mnt/ha-config -> mnt-ha\x2dconfig.mount  (and .automount)
mount_unit="$(systemd-escape --path --suffix=mount "$HA_MOUNT_POINT")"
automount_unit="${mount_unit%.mount}.automount"
unit_dir="/etc/systemd/system"
mount_path="$unit_dir/$mount_unit"
automount_path="$unit_dir/$automount_unit"

# 4. Build sshfs option list.
#   IdentityFile + IdentitiesOnly  -- ignore root's other keys
#   StrictHostKeyChecking=accept-new + isolated known_hosts -- TOFU on LAN
#   reconnect, ServerAliveInterval -- survive HA addon restarts
#   default_permissions, allow_other -- let non-root users see the mount
#   uid/gid                        -- files appear owned by the invoking user
#   _netdev                        -- systemd waits for network
sshfs_opts=(
  "IdentityFile=$key_dst"
  "IdentitiesOnly=yes"
  "StrictHostKeyChecking=accept-new"
  "UserKnownHostsFile=$known_hosts"
  "reconnect"
  "ServerAliveInterval=15"
  "ServerAliveCountMax=3"
  "default_permissions"
  "allow_other"
  "_netdev"
  "uid=$(id -u "$invoking_user")"
  "gid=$(id -g "$invoking_user")"
)
opts_csv="$(IFS=,; echo "${sshfs_opts[*]}")"

# 5. Write the .mount unit.
cat > "$mount_path" <<EOF
# Managed by setup-ha-automount. Do not edit by hand.
[Unit]
Description=Home Assistant /config (SSHFS) at $HA_MOUNT_POINT
After=network-online.target
Wants=network-online.target

[Mount]
What=${HA_SSH_HOST}:${HA_SSH_REMOTE_PATH}
Where=$HA_MOUNT_POINT
Type=fuse.sshfs
Options=$opts_csv
TimeoutSec=30

[Install]
WantedBy=multi-user.target
EOF
log "wrote $mount_path"

# 6. Write the .automount unit.
cat > "$automount_path" <<EOF
# Managed by setup-ha-automount. Do not edit by hand.
[Unit]
Description=Automount for Home Assistant /config at $HA_MOUNT_POINT

[Automount]
Where=$HA_MOUNT_POINT
TimeoutIdleSec=$HA_IDLE_TIMEOUT

[Install]
WantedBy=multi-user.target
EOF
log "wrote $automount_path"

# 7. Reload systemd. Decide whether to enable the automount or fall back
# to enabling the bare .mount directly (some kernels -- notably some Arch
# builds -- have CONFIG_AUTOFS_FS=y but don't expose /dev/autofs in a way
# systemd accepts; in that case .automount activation fails with
# "Starting of Automount ... unsupported." The .mount unit still works
# fine on its own; we just lose lazy/idle-unmount semantics.
systemctl daemon-reload

# Stop any existing mount so the next access picks up the new options.
systemctl stop "$mount_unit" 2>/dev/null || true

# Probe: try starting the automount. If it works, enable it and disable
# the bare .mount (the automount pulls it in on demand). If it fails with
# "unsupported", fall back to enabling the .mount directly.
systemctl enable --quiet "$automount_unit"
if systemctl start "$automount_unit" 2>/dev/null && \
   systemctl is-active --quiet "$automount_unit"; then
  systemctl disable --quiet "$mount_unit" 2>/dev/null || true
  log "automount enabled and active (lazy mount on first access, idle-unmount after ${HA_IDLE_TIMEOUT}s)"
else
  warn "automount activation failed (kernel/systemd autofs interface unavailable)"
  warn "falling back to a persistent mount: enabling .mount directly"
  systemctl disable --quiet "$automount_unit" 2>/dev/null || true
  systemctl enable --quiet --now "$mount_unit"
  if systemctl is-active --quiet "$mount_unit"; then
    log "persistent mount active at $HA_MOUNT_POINT"
  else
    warn "mount also failed; check 'systemctl status $mount_unit'"
  fi
fi
log ""
log "next steps:"
log "  1. ensure the public key (lib/ha-mount.pub from dev-setup) is in the"
log "     'Terminal & SSH' addon's authorized_keys (HA UI > Configuration tab,"
log "     then restart the addon)."
log "  2. test: ls $HA_MOUNT_POINT  (should mount on first access)"
log ""
log "status:    sudo systemctl status $automount_unit"
log "mount:     sudo systemctl status $mount_unit"
log "manual umount:  sudo umount $HA_MOUNT_POINT"
